{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext"],
		"types": ["@cloudflare/workers-types", "vite/client"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"isolatedModules": true,
		"allowJs": true,
		"checkJs": false
	},
	"include": ["src/index.ts", "src/env.d.ts", "worker-configuration.d.ts"]
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lazymap",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-06",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "routes": [
    { "pattern": "lazymap.us", "custom_domain": true },
    { "pattern": "www.lazymap.us", "custom_domain": true }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application"
  },
  "limits": {
    "cpu_ms": 50000,
    "subrequests": 10000
  },
  "ai": {
    "binding": "laZai"
  },
  "d1_databases": [
    {
      "binding": "laZd1",
      "database_name": "lazymap",
      "database_id": "lazymap"
    }
  ],
  "send_email": [
    {
      "name": "laZem"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "laZkv",
      "id": "lazykv"
    }
  ],
  "r2_buckets": [
    {
      "binding": "laZr2",
      "bucket_name": "lazybucket"
    },
    {
      "binding": "searchlazy",
      "bucket_name": "lazysearchbuckey"
    }
  ],
  "dispatch_namespaces": [
    {
      "binding": "lazydyn",
      "namespace": "lazymap"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "APP_URL": "https://lazymap.us",
    "lazymedia": "lazymedia",
    "lazystream": "lazystream"
  },
  "unsafe": {
    "bindings": [
      {
        "name": "laZrl",
        "type": "ratelimit",
        "namespace_id": "52694",
        "limit": {
          "requests": 1000,
          "window": "60s"
        }
      },
      {
        "name": "laZains",
        "type": "ai_search",
        "namespace": "lazymap"
      },
      {
        "name": "lazyimg",
        "type": "images"
      }
    ]
  }
}
